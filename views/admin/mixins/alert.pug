mixin alert-success(message)
  - if(messages.success)
      div(class="alert alert-success" data-time='5000' show-alert) #{messages.success} <span  close-note>X</span>
mixin alert-error(message)
  - if(messages.error)
      div(class="alert alert-warning" data-time='5000' show-alert) #{messages.error} <span  close-note>X</span>