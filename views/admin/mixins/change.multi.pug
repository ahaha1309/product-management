mixin changeMulti(path)
  form(
            action=path
            method="POST"
            form-change-multi
        )
          .d-flex.align-items-start
               .form-group.mx-2
                   select(name="type" class="form-select text-center")
                     option(disabled selected) -- Chọn hành động --
                     option(value="active") Hoạt động
                     option(value="inactive") Dừng hoạt động
                     option(value="delete") Xóa sản phẩm
                     option(value="position") Cập nhật vị trí
               .form-group
                   input(
               type="text"
               name="ids"
               value=""
               class="form-control d-none "
               input-ids
              )
               button(type="submit" class="btn btn-primary ms-2") Áp dụng  