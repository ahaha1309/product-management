mixin pagination(pagination)
  nav
    ul.pagination
      li.page-item
        a.page-link(href='#' button-pagination=`${pagination.currentPage >1 ?pagination.currentPage-1:pagination.totalPage}`) Previous
      - for(var i=1;i<=pagination.totalPage;i++)
         li(class=`page-item ${pagination.currentPage==i ?"active":""}`)
           a.page-link(href='#' button-pagination=`${i}`) #{i}
      li.page-item
        a.page-link(href='#' button-pagination=`${pagination.currentPage <pagination.totalPage ?pagination.currentPage+1:1}`) Next