extends ../../layout/default.pug 
include ../../mixins/moment.pug
block main 
  include ../../mixins/alert.pug
  +alert-success(messages.success)
  h1 Danh sách sản phẩm
  if(role.permission.includes('products_view'))
    .card.mb-2 
      .card-header Bộ lọc tìm kiếm
      .card-body 
        .row 
          .col-6
            include ../../mixins/filllter.status.pug 
            +fillterStatus(button)
          .col-6
            include ../../mixins/form.search.pug 
            +formSearch(keyword)
    include ../../mixins/sort.pug 
    +sort()
    .card.mb-2
      .card-header Danh sách
      .card-body 
        .row.pb-2 
            .col-8
              if(role.permission.includes('products_edit'))
                include ../../mixins/change.multi.pug
                +changeMulti(`${prefixAdmin}/product/change-multi?_method=PATCH`)
            .col-4 
              if(role.permission.includes('products_create'))
                 a(href=`${prefixAdmin}/product/create` class="btn btn-outline-success float-end ") Thêm mới

        table.table.table-hover.table-sm
          thead 
            tr  
              th 
                input(type="checkbox" name="checkall")
              th STT 
              th Hình ảnh
              th Tiêu đề
              th Giá
              th Vị trí
              th Trạng thái
              th Created By
              th Updated By
              th Hành động 
          tbody 
            each Item,Index in product
              tr 
                td 
                    input(type="checkbox" name="id" value=Item.id multi-status)
                td #{pagination.limit*(pagination.currentPage-1)+(Index+1)}
                td 
                  img(
                src=Item.thumbnail
                alt=Item.title
                width="100px"
                height="auto"
                )
                td #{Item.title}
                td #{Item.price}$
                td 
                  input(
                  type="number"
                  name="position"
                  value=Item.position
                  min="1"
                  style="width: 60px"
                  )
                td 
                   if(role.permission.includes('products_edit'))
                      a(
                      href="javascript:;"
                      class=`badge text-bg-${Item.status=="active" ? "success" :"danger"}`
                      button-change-status
                      data-status=Item.status 
                      button-id=Item.id
                      ) #{Item.status=="active" ? "Hoạt động" :"Dừng hoạt động"}
                   else
                      span(class=`badge text-bg-${Item.status=="active" ? "success" :"danger"}`) #{Item.status=="active" ? "Hoạt động" :"Dừng hoạt động"}
                td 
                   p #{Item.fullname}
                   if(Item.createdBy)
                     +formatDateTime(Item.createdBy.createdAt)
                td 
                   p #{Item.updatedByName}
                   if(Item.updatedBy && Item.updatedBy.length > 0)
                     +formatDateTime(Item.updatedBy[Item.updatedBy.length - 1].updatedAt)
                td
                  a(href=`${prefixAdmin}/product/detail/${Item.id}` class="btn btn-secondary btn-sm mx-1" button-change-activity="fix" btn-id=Item.id) Chi tiết
                  if(role.permission.includes('products_edit'))
                    a(href=`${prefixAdmin}/product/edit/${Item.id}` class="btn btn-warning btn-sm" button-change-activity="fix" btn-id=Item.id) Sửa 
                  if(role.permission.includes('products_delete'))
                    button(class="btn btn-danger btn-sm ms-1" button-change-activity="delete" btn-id=Item.id) Xóa

    include ../../mixins/pagination 
    +pagination(pagination)

    form(
      action=""
      method="POST"
      id="form-change-status"
      data-path=`${prefixAdmin}/product/change-status`
    ) 
    form(
      action=""
      method="POST"
      id="form-change-activity"
      data-path=`${prefixAdmin}/product/change-activity`
    ) 
  else 
    .alert.alert-danger Bạn không có quyền xem sản phẩm
  script(src="/admin/js/product.js") 