doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Đăng nhập Admin

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    style.
      body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .login-card {
        width: 400px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      }

  body
    include ../../mixins/alert.pug
    +alert-error(messages.error)
    .card.login-card.p-4
      h3.text-center.mb-4 Đăng nhập Admin

      form(action="/admin/auth/login" method="POST")

        .mb-3
          label.form-label Email
          input.form-control(
            type="email"
            name="email"
            placeholder="Nhập email"
            required
          )

        .mb-3
          label.form-label Mật khẩu
          input.form-control(
            type="password"
            name="password"
            placeholder="Nhập mật khẩu"
            required
          )

        .mb-3.form-check
          input.form-check-input(type="checkbox" id="remember")
          label.form-check-label(for="remember") Ghi nhớ đăng nhập

        button.btn.btn-primary.w-100(type="submit") Đăng nhập

        .text-center.mt-3
          a(href="#") Quên mật khẩu?