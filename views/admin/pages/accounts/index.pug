extends ../../layout/default.pug 
block main 
  include ../../mixins/alert.pug
  +alert-success(messages.success)
  h1 Danh sách tài khoản
  .card.mb-2 
    .card-header Bộ lọc tìm kiếm
    .card-body 
       .row 
         .col-6
           include ../../mixins/filllter.status.pug 
           +fillterStatus(button)
         .col-6
           include ../../mixins/form.search.pug 
           +formSearch(keyword)
  
  .card.mb-2
    .card-header Danh sách
    .card-body 
       .row.pb-2 
          .col-8
          .col-4 
            a(href=`${prefixAdmin}/accounts/create` class="btn btn-outline-success float-end ") Thêm mới
       table.table.table-hover.table-sm
         thead 
           tr  
             th STT 
             th Avatar
             th Họ tên
             th Phân quyền
             th Email
             th Trạng thái
             th Hành động 
         tbody 
           each Item,Index in accounts
            tr 
               td #{Index+1}
               td 
                img(
               src=Item.avatar
               alt=Item.title
               width="100px"
               height="auto"
               )
               td #{Item.fullname}
               if(Item.roleId)
                  each role in roles
                    if(role._id.toString()===Item.roleId.toString())
                      td #{role.title}
               else
                 td Chưa phân quyền
               td #{Item.email}
               td 
                 a(
                 href="javascript:;"
                 class=`badge text-bg-${Item.status=="active" ? "success" :"danger"}`
                 button-change-status
                 data-status=Item.status 
                 button-id=Item.id
                ) #{Item.status=="active" ? "Hoạt động" :"Dừng hoạt động"}
               td
                 a(href=`${prefixAdmin}/accounts/detail/${Item.id}` class="btn btn-secondary btn-sm mx-1" button-change-activity="fix" btn-id=Item.id) Chi tiết
                 a(href=`${prefixAdmin}/accounts/edit/${Item.id}` class="btn btn-warning btn-sm" button-change-activity="fix" btn-id=Item.id) Sửa 
                 button(class="btn btn-danger btn-sm ms-1" button-change-activity="delete" btn-id=Item.id) Xóa
    form(
      action=""
      method="POST"
      id="form-change-status"
      data-path=`${prefixAdmin}/accounts/change-status`
    ) 
    form(
      action=""
      method="POST"
      id="form-change-activity"
      data-path=`${prefixAdmin}/accounts/change-activity`
    ) 
  
    script(src="/admin/js/product.js") 