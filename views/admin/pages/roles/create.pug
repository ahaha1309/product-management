extends ../../layout/default.pug
include ../../mixins/select-tree.pug
block main
  include ../../mixins/alert.pug
  +alert-error(messages.error)
  h1 Thêm nhóm quyền
  form(action=`${prefixAdmin}/roles/create` method="POST" )
    .mb-3
      label.form-label Tiêu đề
      input.form-control(type="text" name="title" placeholder="Nhập tiêu đề nhóm quyền" required)
    .mb-3 
      label.form-label Mô tả
      textarea.form-control(name="description" id='' placeholder="Nhập mô tả nhóm quyền" )
    button.btn.btn-success(type="submit") Thêm mới
  script(src='/admin/js/product.js')