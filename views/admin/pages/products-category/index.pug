extends ../../layout/default.pug 
block main 
  include ../../mixins/alert.pug
  +alert-success(messages.success)
  h1 Danh mục sản phẩm
  .card.mb-2 
    .card-header Bộ lọc tìm kiếm
    .card-body 
       .row 
         .col-6
           include ../../mixins/filllter.status.pug 
           +fillterStatus(button)
         .col-6
           include ../../mixins/form.search.pug 
           +formSearch(keyword)
  include ../../mixins/sort.pug 
  +sortCategory()
  .card.mb-2
    .card-header Danh sách
    .card-body 
       .row.pb-2 
          .col-8
            include ../../mixins/change.multi.pug
            +changeMulti(`${prefixAdmin}/category-product/change-multi?_method=PATCH`)
          .col-4 
            a(href=`${prefixAdmin}/category-product/create` class="btn btn-outline-success float-end ") Thêm mới
       table.table.table-hover.table-sm
         thead 
           tr  
             th 
               input(type="checkbox" name="checkall")
             th STT 
             th Hình ảnh
             th Tiêu đề
             th Vị trí
             th Trạng thái
             th Hành động 
         tbody 
           each Item,Index in categoryProduct
            tr 
               td 
                  input(type="checkbox" name="id" value=Item.id multi-status)
               td #{Index+1}
               td 
                img(
               src=Item.thumbnail
               alt=Item.title
               width="100px"
               height="auto"
               )
               td #{Item.title}
               td 
                input(
                 type="number"
                 name="position"
                 value=Item.position
                 min="1"
                 style="width: 60px"
                )
               td 
                 a(
                 href="javascript:;"
                 class=`badge text-bg-${Item.status=="active" ? "success" :"danger"}`
                 button-change-status
                 data-status=Item.status 
                 button-id=Item.id
                ) #{Item.status=="active" ? "Hoạt động" :"Dừng hoạt động"}
               td
                 a(href=`${prefixAdmin}/products-category/detail/${Item.id}` class="btn btn-secondary btn-sm mx-1" button-change-activity="fix" btn-id=Item.id) Chi tiết
                 a(href=`${prefixAdmin}/products-category/edit/${Item.id}` class="btn btn-warning btn-sm" button-change-activity="fix" btn-id=Item.id) Sửa 
                 button(class="btn btn-danger btn-sm ms-1" button-change-activity="delete" btn-id=Item.id) Xóa

  //- include ../../mixins/pagination 
  //- +pagination(pagination)

  form(
     action=""
     method="POST"
     id="form-change-status"
     data-path=`${prefixAdmin}/category-product/change-status`
  ) 
  form(
     action=""
     method="POST"
     id="form-change-activity"
     data-path=`${prefixAdmin}/category-product/change-activity`
  ) 
  
  
  script(src="/admin/js/index.js") 