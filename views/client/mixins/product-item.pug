mixin product-item(Item)
          .col-3.mb-3.shadow-sm.ms-2 
             .product-item 
                .product-image 
                   .inner-image
                      img(src=Item.thumbnail,alt=Item.title)
                   .inner-info 
                      a.inner-title(href=`/product/detail/${Item.slug}`) #{Item.title}
                      .inner-price-new #{Item.priceNew}$
                      if(Item.featured==true)
                        .inner-feature Nổi bật
                      .inner-price-old(style="text-decoration: line-through;") #{Item.price}$
                      .inner-discount.bg-danger #{Item.discountPercentage}%