include ../../mixins/alert.pug
doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Đăng ký tài khoản
    
    //- Nhúng Bootstrap 5
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    
    //- Nhúng file CSS (Dùng chung file style.css của trang Login)
    link(rel="stylesheet" href="/css/style.css")

  body.auth-page
    if(messages.success)
       +alert-success(messages.success)
    if(messages.error)
       +alert-error(messages.error)
    .login-container
      .login-card
        .login-header.text-center.mb-4
          h1.brand-logo DACA
          p.text-muted Cộng tác cùng phát triển

        h3.text-center.fw-bold.mb-4 Đăng Ký

        form(action="/auth/register" method="POST")
          //- Trường Họ và tên
          .form-group.mb-3
            label.form-label.fw-bold(for="fullName") Họ và tên
            input#fullName.form-control.input-custom(
              type="text"
              name="fullName"
              placeholder="Nhập họ tên của bạn"
              required
            )
          
          //- Trường Email
          .form-group.mb-3
            label.form-label.fw-bold(for="email") Email
            input#email.form-control.input-custom(
              type="email"
              name="email"
              placeholder="Nhập email"
              required
            )
          
          //- Trường Mật khẩu
          .form-group.mb-3
            label.form-label.fw-bold(for="password") Mật khẩu
            input#password.form-control.input-custom(
              type="password"
              name="password"
              placeholder="Tạo mật khẩu (ít nhất 6 ký tự)"
              minlength="6"
              required
            )

          //- Trường Xác nhận mật khẩu
          .form-group.mb-4
            label.form-label.fw-bold(for="confirmPassword") Xác nhận mật khẩu
            input#confirmPassword.form-control.input-custom(
              type="password"
              name="confirmPassword"
              placeholder="Nhập lại mật khẩu"
              minlength="6"
              required
            )
          
          button.btn.btn-success.w-100.btn-auth(type="submit") ĐĂNG KÝ
        
        //- Link quay lại trang Đăng nhập
        .text-center.mt-4
          span.text-muted Đã có tài khoản? 
          a.auth-link.fw-bold(href="/auth/login") Đăng nhập ngay