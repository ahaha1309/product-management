include ../../mixins/alert.pug
doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Đăng nhập hệ thống
    
    //- Nhúng Bootstrap 5 qua CDN
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    
    //- Nhúng file CSS của bạn
    link(rel="stylesheet" href="/css/style.css")

  body.auth-page
    +alert-success(messages.success)
    .login-container
      .login-card
        .login-header.text-center.mb-4
          //- Bạn có thể thay bằng thẻ img chứa logo thật của bạn
          h1.brand-logo DACA
          p.text-muted Cộng tác cùng phát triển

        h3.text-center.fw-bold.mb-4 Đăng Nhập

        form(action="/auth/login" method="POST")
          .form-group.mb-3
            label.form-label.fw-bold(for="email") Email
            input#email.form-control.input-custom(
              type="email"
              name="email"
              placeholder="Nhập email của bạn"
              required
            )
          
          .form-group.mb-3
            label.form-label.fw-bold(for="password") Mật khẩu
            input#password.form-control.input-custom(
              type="password"
              name="password"
              placeholder="Nhập mật khẩu"
              required
            )
          
          .d-flex.justify-content-between.align-items-center.mb-4
            .form-check
              input#remember.form-check-input(type="checkbox" name="remember")
              label.form-check-label.show-text(for="remember") Hiện mật khẩu
            a.auth-link(href="/user/password/forgot") Quên mật khẩu?
          
          button.btn.btn-success.w-100.btn-auth(type="submit") ĐĂNG NHẬP
        
        .text-center.mt-4
          span.text-muted Chưa có tài khoản? 
          a.auth-link.fw-bold(href="/auth/register") Đăng ký ngay